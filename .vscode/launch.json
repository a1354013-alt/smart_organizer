{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Smart Organizer: Streamlit App",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py",
        "--server.address",
        "localhost",
        "--server.port",
        "8501"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
