[run]
branch = True
source = .
omit =
    tests/*
    release_ci/*
    release/*
    coverage.xml
    htmlcov/*
    uploads/*
    repository/*
    repo/*
    logs/*
    manifests/*
    previews/*
    quarantine/*
    *.lock.txt
    */extracted/*
    */.pytest_cache/*
    */__pycache__/*
    */site-packages/*
    .venv/*
    venv/*

[report]
fail_under = 75
show_missing = True
# Release zip verification extracts temporary files that are not project source.
omit =
    tests/*
    release_ci/*
    release/*
    htmlcov/*
    uploads/*
    repository/*
    repo/*
    logs/*
    manifests/*
    previews/*
    quarantine/*
    */extracted/*
    */.pytest_cache/*
    */__pycache__/*
    */site-packages/*
    .venv/*
    venv/*
