```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Test directories
tests/_tmp_pytest/

# Logs
*.log

# Temporary files
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE files
.vscode/
.idea/

# Build artifacts
build/
dist/
*.so
*.dylib
*.dll
*.exe
*.out

# Dependencies
.venv/
venv/
node_modules/

# OS files
.DS_Store
Thumbs.db
```